@echo off
chcp 65001 >nul
title Auto Tester - Universe MapMaker

REM Get the script's directory
set SCRIPT_DIR=%~dp0
set BASE_DIR=%SCRIPT_DIR%..

REM Remove stop signal
del /Q "%BASE_DIR%\monitor\stop-signal.txt" 2>nul

REM Reset tests-data.js to initial state
echo // Auto-generated by Agent Tester> "%BASE_DIR%\monitor\tests-data.js"
echo var testData = {>> "%BASE_DIR%\monitor\tests-data.js"
echo   "lastUpdate": "",>> "%BASE_DIR%\monitor\tests-data.js"
echo   "agentStatus": {"isRunning": false, "finished": false},>> "%BASE_DIR%\monitor\tests-data.js"
echo   "summary": {},>> "%BASE_DIR%\monitor\tests-data.js"
echo   "tests": []>> "%BASE_DIR%\monitor\tests-data.js"
echo };>> "%BASE_DIR%\monitor\tests-data.js"

echo.
echo ========================================
echo   Universe MapMaker - Auto Tester
echo ========================================
echo.
echo Uruchamiam serwer na http://localhost:8080
echo Przegladarka otworzy sie automatycznie.
echo.
echo Aby ZATRZYMAC testy, uruchom: stop-testing.bat
echo lub nacisnij Ctrl+C w tym oknie.
echo.

REM Open browser (delayed to let server start)
start "" "http://localhost:8080"

REM Start server (this blocks until Ctrl+C)
cd /d "%BASE_DIR%\scripts"
node server.js

echo.
echo Serwer zatrzymany.
pause
