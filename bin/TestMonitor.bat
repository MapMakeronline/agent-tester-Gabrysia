@echo off
title Test Monitor - Universe MapMaker
cd /d "%~dp0"

:: Zatrzymaj poprzedni serwer jeśli działa
curl -s http://localhost:8081/api/stop >nul 2>&1
taskkill /F /IM node.exe /FI "WINDOWTITLE eq Test Monitor*" >nul 2>&1

:: Resetuj dane testów (nowa sesja)
echo // Auto-generated by Auto Tester > "..\monitor\tests-data.js"
echo var testData = { >> "..\monitor\tests-data.js"
echo   "lastUpdate": null, >> "..\monitor\tests-data.js"
echo   "sheetId": "", >> "..\monitor\tests-data.js"
echo   "sheetUrl": "", >> "..\monitor\tests-data.js"
echo   "sheetTitle": "", >> "..\monitor\tests-data.js"
echo   "agentStatus": { >> "..\monitor\tests-data.js"
echo     "isRunning": false, >> "..\monitor\tests-data.js"
echo     "currentAction": "", >> "..\monitor\tests-data.js"
echo     "lastAction": null, >> "..\monitor\tests-data.js"
echo     "finished": false, >> "..\monitor\tests-data.js"
echo     "startedAt": null, >> "..\monitor\tests-data.js"
echo     "finishedAt": null >> "..\monitor\tests-data.js"
echo   }, >> "..\monitor\tests-data.js"
echo   "summary": { >> "..\monitor\tests-data.js"
echo     "total": 0, >> "..\monitor\tests-data.js"
echo     "passed": 0, >> "..\monitor\tests-data.js"
echo     "failed": 0, >> "..\monitor\tests-data.js"
echo     "blocked": 0, >> "..\monitor\tests-data.js"
echo     "inProgress": 0, >> "..\monitor\tests-data.js"
echo     "pending": 0, >> "..\monitor\tests-data.js"
echo     "skipped": 0 >> "..\monitor\tests-data.js"
echo   }, >> "..\monitor\tests-data.js"
echo   "currentTest": null, >> "..\monitor\tests-data.js"
echo   "tests": [] >> "..\monitor\tests-data.js"
echo }; >> "..\monitor\tests-data.js"

:: Usuń sygnał stopu
del "..\monitor\stop-signal.txt" >nul 2>&1

:: Uruchom serwer
cd /d "%~dp0\..\scripts"
echo.
echo ========================================
echo   Test Monitor - Universe MapMaker
echo ========================================
echo.

:: Sprawdź czy port jest wolny
netstat -ano | findstr ":8081" >nul 2>&1
if %errorlevel%==0 (
    echo Port 8081 zajety, zamykam poprzedni serwer...
    for /f "tokens=5" %%a in ('netstat -ano ^| findstr ":8081" ^| findstr "LISTENING"') do (
        taskkill /F /PID %%a >nul 2>&1
    )
    timeout /t 2 /nobreak >nul
)

:: Uruchom serwer w nowym oknie
start "Test Monitor Server" /min cmd /c "node server.js"

:: Poczekaj na uruchomienie
timeout /t 2 /nobreak >nul

:: Otwórz przeglądarkę
start http://localhost:8081

echo Serwer uruchomiony na http://localhost:8081
echo.
echo Nacisnij dowolny klawisz aby zamknac serwer...
pause >nul

:: Zatrzymaj serwer
taskkill /F /FI "WINDOWTITLE eq Test Monitor Server" >nul 2>&1
